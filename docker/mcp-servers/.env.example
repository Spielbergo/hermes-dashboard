# ── Sheets MCP service account credentials ────────────────────────────────
# Base64-encode your service account JSON key:
#   Windows PowerShell:
#     [Convert]::ToBase64String([IO.File]::ReadAllBytes("path\to\sa-key.json"))
#   Linux/macOS:
#     base64 -w 0 sa-key.json
SHEETS_SA_CREDENTIALS_B64=

# Google Drive folder ID shared with the service account
# Get from Drive URL: https://drive.google.com/drive/folders/THIS_IS_THE_ID
SHEETS_DRIVE_FOLDER_ID=
