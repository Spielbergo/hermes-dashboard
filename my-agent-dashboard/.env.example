# === LLM ===
LLM_PROVIDER=gemini # Or your preferred provider
LLM_MODEL=gemini-2.5-flash-lite

# === Telegram ===
# TELEGRAM_BOT_TOKEN=
# ALLOWED_USER_IDS=

# === Identity ===
USER_NAME=ScottAI # Or your preferred name
USER_TIMEZONE=UTC

# === Memory ===
# On VPS with Docker: DB is mounted into the container at /data/memory.db
DB_PATH=/data/memory.db
# Local dev only: point directly at Hermes's db file
# DB_PATH=../hermes-agent/data/memory.db

# === Pinecone (Optional) ===
# PINECONE_API_KEY=
# PINECONE_INDEX=my-agent

# === Supabase (Optional) ===
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# === Dashboard ===
DASHBOARD_TOKEN=your_secret_dashboard_token_here # Generate a strong, unique token
PORT=5173
# CORS_ORIGIN=http://localhost:5174 # Only needed for local dev with a separate frontend dev server
