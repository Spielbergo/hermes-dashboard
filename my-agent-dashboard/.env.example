# === Dashboard ===
DASHBOARD_TOKEN=your_secret_dashboard_token_here
PORT=5173

# === Agents ===
# Semicolon-separated list of agents: id:Display Name:/path/to/state.db
# The paths here are container-internal mount points (see docker-compose.yml volumes)
AGENTS=cli:Hermes CLI:/data/cli/state.db;webui:Hermes WebUI:/data/webui/state.db

# Single-agent fallback (used if AGENTS is not set)
# DB_PATH=/data/state.db

# CORS_ORIGIN=http://localhost:5174  # Only needed for local dev with a separate frontend
